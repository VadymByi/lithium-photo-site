// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  }

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique // Наш будущий URL
  description String?  @db.Text
  mainImage   String?  // Ссылка на обложку проекта
  createdAt   DateTime @default(now())
  photos      Photo[]
}

model Photo {
  id          String   @id @default(cuid())
  url         String
  secureUrl   String   // HTTPS версия
  publicId    String   @unique
  width       Int
  height      Int
  format      String?
  title       String?
  alt         String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  mainSliderItems MainSliderItem[]
  portfolioItems PortfolioItem[]
}



// Models for  Auth.js

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model MainSliderItem {
  id              String   @id @default(cuid())
  title           String?  // Заголовок на слайде
  description     String?  // Подзаголовок или описание
  backgroundColor String   @default("#111111") // Цвет левой панели
  order           Int      @default(0) // Порядок показа

  // Связь с конкретной фотографией
  photoId         String
  photo           Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteConfig {
  id            Int     @id @default(1)
  showAbout     Boolean @default(true)
  showPortfolio Boolean @default(true)
  showProjects  Boolean @default(true)
  showContacts  Boolean @default(true)
  aboutTitle     String  @default("About")
  aboutText      String  @default("Place your biography here...")
  aboutImageUrl  String?
}


model PortfolioItem {
  id        String   @id @default(cuid())
  order     Int      @default(0)

  photoId   String
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
